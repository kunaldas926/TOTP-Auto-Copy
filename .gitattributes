# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source files
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf
README text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binary files
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Archives
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.rar binary

# Git attributes for GitHub linguist
*.md linguist-documentation
*.json linguist-language=JSON
.github/** linguist-vendored

# Diff settings
*.json diff=json
*.md diff=markdown
